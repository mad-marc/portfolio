---
import BaseLayout from '../../layouts/BaseLayout.astro';

const posts = await Astro.glob('./*.md');
const sorted = posts.sort((a, b) =>
  new Date(b.frontmatter.date).getTime() - new Date(a.frontmatter.date).getTime()
);
---

<BaseLayout title="Thoughts — Marc Solé Domènech">
  <h1 class="text-2xl font-semibold mb-3">Thoughts</h1>
  <p class="text-neutral-500 text-sm mb-12">Writing about product, leadership, and building teams.</p>

  {sorted.length === 0 ? (
    <p class="text-sm text-neutral-400">No posts yet. Check back soon.</p>
  ) : (
    <ul class="space-y-8">
      {sorted.map((post) => (
        <li class="border-t border-neutral-100 pt-6">
          <a href={post.url} class="group">
            <div class="flex items-baseline justify-between gap-4 mb-1">
              <h2 class="text-sm font-medium text-neutral-900 group-hover:text-neutral-500 transition-colors">
                {post.frontmatter.title}
              </h2>
              <span class="text-xs text-neutral-400 shrink-0">
                {new Date(post.frontmatter.date).toLocaleDateString('en-US', { month: 'short', year: 'numeric' })}
              </span>
            </div>
            {post.frontmatter.excerpt && (
              <p class="text-sm text-neutral-500">{post.frontmatter.excerpt}</p>
            )}
          </a>
        </li>
      ))}
    </ul>
  )}
</BaseLayout>
