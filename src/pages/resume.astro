---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Resume — Marc Solé Domènech">
  <div class="flex items-start justify-between mb-12">
    <div>
      <h1 class="text-2xl font-semibold mb-1">Marc Solé Domènech</h1>
      <p class="text-neutral-500 text-sm">Product Management Leadership</p>
    </div>
    <a href="/contact" class="text-xs text-neutral-400 hover:text-neutral-900 transition-colors">Contact →</a>
  </div>

  <section class="mb-12">
    <h2 class="text-xs font-medium uppercase tracking-widest text-neutral-400 mb-6">Experience</h2>
    <ul class="space-y-8">
      <li class="border-t border-neutral-100 pt-6">
        <div class="flex items-baseline justify-between mb-1">
          <h3 class="text-sm font-medium text-neutral-900">Job Title — Company Name</h3>
          <span class="text-xs text-neutral-400">2022 — Present</span>
        </div>
        <p class="text-sm text-neutral-500 leading-relaxed">
          A brief description of your role, impact, and what you built or led.
        </p>
      </li>
      <li class="border-t border-neutral-100 pt-6">
        <div class="flex items-baseline justify-between mb-1">
          <h3 class="text-sm font-medium text-neutral-900">Job Title — Company Name</h3>
          <span class="text-xs text-neutral-400">2019 — 2022</span>
        </div>
        <p class="text-sm text-neutral-500 leading-relaxed">
          A brief description of your role, impact, and what you built or led.
        </p>
      </li>
      <li class="border-t border-neutral-100 pt-6">
        <div class="flex items-baseline justify-between mb-1">
          <h3 class="text-sm font-medium text-neutral-900">Job Title — Company Name</h3>
          <span class="text-xs text-neutral-400">2016 — 2019</span>
        </div>
        <p class="text-sm text-neutral-500 leading-relaxed">
          A brief description of your role, impact, and what you built or led.
        </p>
      </li>
    </ul>
  </section>

  <section class="mb-12">
    <h2 class="text-xs font-medium uppercase tracking-widest text-neutral-400 mb-6">Education</h2>
    <ul class="space-y-6">
      <li class="border-t border-neutral-100 pt-6">
        <div class="flex items-baseline justify-between mb-1">
          <h3 class="text-sm font-medium text-neutral-900">Degree — University Name</h3>
          <span class="text-xs text-neutral-400">Year</span>
        </div>
      </li>
    </ul>
  </section>

  <section>
    <h2 class="text-xs font-medium uppercase tracking-widest text-neutral-400 mb-6">Skills</h2>
    <div class="flex flex-wrap gap-2">
      {["Product Strategy", "Roadmapping", "Team Leadership", "Stakeholder Management",
        "0→1 Products", "Agile", "OKRs", "User Research"].map(skill => (
        <span class="text-xs text-neutral-500 bg-neutral-50 px-3 py-1 rounded">{skill}</span>
      ))}
    </div>
  </section>
</BaseLayout>
