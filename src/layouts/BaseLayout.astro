---
interface Props {
  title: string;
  description?: string;
}

const { title, description = "Marc Solé Domènech — Product Management Leadership" } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet" />
  </head>
  <style is:global>
    .reveal {
      opacity: 0;
      transform: translateY(12px);
      transition: opacity 0.4s ease-out, transform 0.4s ease-out;
    }
    .reveal.visible {
      opacity: 1;
      transform: translateY(0);
    }
    .reveal-delay-1 { transition-delay: 0.06s; }
    .reveal-delay-2 { transition-delay: 0.12s; }
    .reveal-delay-3 { transition-delay: 0.18s; }
    .reveal-delay-4 { transition-delay: 0.24s; }

    /* Loading screen */
    #loading-screen {
      position: fixed;
      inset: 0;
      background-color: #C8614A;
      z-index: 9999;
      display: flex;
      align-items: center;
      justify-content: center;
      pointer-events: none;
    }
    #loading-screen.fade-out {
      transition: opacity 0.45s ease-out;
      opacity: 0;
    }
    #loading-logo {
      opacity: 0;
    }
    @keyframes logo-popin {
      0%   { transform: scale(0.4) rotate(-10deg); opacity: 0; }
      65%  { transform: scale(1.12) rotate(3deg);  opacity: 1; }
      100% { transform: scale(1)    rotate(0deg);  opacity: 1; }
    }
    @keyframes logo-shake {
      0%,  100% { transform: translateX(0)    rotate(0deg);   }
      12%        { transform: translateX(-9px)  rotate(-6deg); }
      25%        { transform: translateX(9px)   rotate(6deg);  }
      37%        { transform: translateX(-7px)  rotate(-4deg); }
      50%        { transform: translateX(7px)   rotate(4deg);  }
      62%        { transform: translateX(-4px)  rotate(-2deg); }
      75%        { transform: translateX(4px)   rotate(2deg);  }
      87%        { transform: translateX(-2px)  rotate(-1deg); }
    }
    @keyframes logo-spin {
      0%   { transform: rotate(0deg)   scale(1);   opacity: 1; }
      55%  { transform: rotate(220deg) scale(1.2); opacity: 1; }
      100% { transform: rotate(360deg) scale(0.6); opacity: 0; }
    }
  </style>
  <body class="min-h-screen font-sans">
    <div id="loading-screen" aria-hidden="true">
      <div id="loading-logo">
        <svg width="88" height="80" viewBox="0 0 88 80" fill="none" xmlns="http://www.w3.org/2000/svg">
          <polygon points="44,4 84,76 4,76" fill="white"/>
          <text x="44" y="66" font-family="serif" font-size="26" fill="#C8614A" text-anchor="middle">M</text>
        </svg>
      </div>
    </div>
    <header class="max-w-2xl mx-auto px-6 py-8">
      <nav class="flex items-center justify-between">
        <a href="/" class="text-sm font-medium text-neutral-900 hover:text-neutral-500 transition-colors">
          Marc Solé Domènech
        </a>
        <ul class="flex gap-6 text-sm text-neutral-500">
          <li><a href="/projects" class="hover:text-neutral-900 transition-colors">Projects</a></li>
          <li><a href="/blog" class="hover:text-neutral-900 transition-colors">Thoughts</a></li>
          <li><a href="/resume" class="hover:text-neutral-900 transition-colors">Resume</a></li>
          <li><a href="/contact" class="hover:text-neutral-900 transition-colors">Contact</a></li>
        </ul>
      </nav>
    </header>

    <main class="max-w-2xl mx-auto px-6 py-12">
      <slot />
    </main>

    <footer class="max-w-2xl mx-auto px-6 py-8 mt-20 border-t border-neutral-100">
      <p class="text-sm text-neutral-400">© {new Date().getFullYear()} Marc Solé Domènech</p>
    </footer>

    <script>
      // Loading animation sequence
      const screen = document.getElementById('loading-screen');
      const logo   = document.getElementById('loading-logo');

      if (screen && logo) {
        document.body.style.overflow = 'hidden';

        // Pop-in
        setTimeout(() => {
          logo.style.animation = 'logo-popin 0.38s cubic-bezier(0.34, 1.56, 0.64, 1) forwards';
        }, 150);

        // Shake (after pop-in)
        setTimeout(() => {
          logo.style.animation = 'logo-shake 0.72s ease-in-out';
        }, 620);

        // Spin (after shake)
        setTimeout(() => {
          logo.style.animation = 'logo-spin 0.65s ease-in-out forwards';
        }, 1420);

        // Fade out screen mid-spin
        setTimeout(() => {
          screen.classList.add('fade-out');
        }, 1700);

        // Remove screen and restore scroll
        setTimeout(() => {
          screen.remove();
          document.body.style.overflow = '';
        }, 2180);

        // Safety fallback
        setTimeout(() => {
          screen.remove();
          document.body.style.overflow = '';
        }, 4000);
      }

      // Reveal on scroll
      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.classList.add('visible');
          }
        });
      }, { threshold: 0.1 });

      document.querySelectorAll('.reveal').forEach(el => observer.observe(el));

      // Parallax on profile image (RAF throttled)
      const img = document.getElementById('profile-img');
      if (img) {
        let ticking = false;
        window.addEventListener('scroll', () => {
          if (!ticking) {
            requestAnimationFrame(() => {
              img.style.transform = `translateY(${window.scrollY * 0.1}px)`;
              ticking = false;
            });
            ticking = true;
          }
        }, { passive: true });
      }
    </script>
  </body>
</html>
