---
import BaseLayout from './BaseLayout.astro';

const { frontmatter } = Astro.props;
---

<BaseLayout title={`${frontmatter.title} — Marc Solé Domènech`} description={frontmatter.excerpt}>
  <article>
    <div class="mb-10">
      <a href="/blog" class="text-xs text-neutral-400 hover:text-neutral-900 transition-colors">← All posts</a>
    </div>

    <header class="mb-10">
      <h1 class="text-2xl font-semibold mb-3">{frontmatter.title}</h1>
      <time class="text-sm text-neutral-400">
        {new Date(frontmatter.date).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}
      </time>
    </header>

    <div class="prose prose-neutral max-w-none text-neutral-700 leading-relaxed
      [&>p]:mb-5 [&>h2]:text-base [&>h2]:font-semibold [&>h2]:mt-10 [&>h2]:mb-4
      [&>ul]:list-disc [&>ul]:pl-5 [&>ul]:space-y-2 [&>ul]:text-sm">
      <slot />
    </div>
  </article>
</BaseLayout>
